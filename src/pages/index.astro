---
import Layout from '../layouts/Layout.astro';
import rankings from '../data/rankings.json';
import artistData from '../data/artists.json';

function formatNumber(n: number): string {
  if (n >= 1_000_000) return (n / 1_000_000).toFixed(1) + 'M';
  if (n >= 1_000) return (n / 1_000).toFixed(0) + 'K';
  return n.toString();
}

function changeLabel(change: number | null): string {
  if (change === null) return '<span class="change-new">NEW</span>';
  if (change > 0) return `<span class="change-up">▲${change}</span>`;
  if (change < 0) return `<span class="change-down">▼${Math.abs(change)}</span>`;
  return '<span class="change-same">-</span>';
}

const genres = artistData.genres;
const base = import.meta.env.BASE_URL;
const allArtists = rankings.artists || [];

// ジャンルごとに最低20件確保するため、全アーティストをジャンル別にカウント
const genreCounts: Record<string, number> = {};
const selected: Set<number> = new Set();

// まず全体ランキング上位を追加
for (let i = 0; i < allArtists.length; i++) {
  const a = allArtists[i];
  genreCounts[a.genre] = (genreCounts[a.genre] || 0);
  // 全ジャンルが20件に達するまで追加
  if (genreCounts[a.genre] < 20) {
    selected.add(i);
    genreCounts[a.genre]++;
  }
}

const top20 = allArtists.filter((_, i) => selected.has(i));
---

<Layout title="Music Ranking - トレンド音楽ランキング">
  <div class="hero">
    <h1>Music Ranking</h1>
    <p class="subtitle">トレンド音楽ランキング</p>
    <p class="update">Last updated: {new Date(rankings.fetchedAt).toLocaleDateString('ja-JP')}</p>
  </div>

  <!-- ジャンルフィルター -->
  <div class="genre-filters">
    <button class="genre-btn active" data-genre="all">すべて</button>
    {genres.map((g) => (
      <button class="genre-btn" data-genre={g.id} style={`--genre-color: ${g.color}`}>
        {g.name}
      </button>
    ))}
  </div>

  <!-- ランキング -->
  <div class="ranking-list">
    {top20.map((artist, i) => (
      <div class="rank-card" data-genre={artist.genre}>
        <div class:list={['rank-number', { gold: i === 0, silver: i === 1, bronze: i === 2 }]}>
          {i + 1}
        </div>
        <div class="change" set:html={changeLabel(artist.change)} />
        <div class="artist-info">
          <div class="artist-name">{artist.name}</div>
          <div class="artist-meta">
            <span class="genre-tag" style={`--tag-color: ${genres.find(g => g.id === artist.genre)?.color || '#888'}`}>
              {genres.find(g => g.id === artist.genre)?.name || artist.genre}
            </span>
            <span class="artist-stats">
              {artist.dailyPlays > 0
                ? `+${formatNumber(artist.dailyPlays)}/day`
                : artist.weeklyPlays > 0
                  ? `+${formatNumber(artist.weeklyPlays)}/week`
                  : `${formatNumber(artist.listeners)} listeners`}
            </span>
          </div>
        </div>
        {artist.spotify_id && (
          <a
            href={`https://open.spotify.com/artist/${artist.spotify_id}`}
            target="_blank"
            class="spotify-link"
            title="Spotifyで聴く"
          >
            <svg viewBox="0 0 24 24" width="24" height="24" fill="#1DB954">
              <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/>
            </svg>
          </a>
        )}
      </div>
    ))}
  </div>

  <div class="no-results" style="display:none;">該当するアーティストがいません</div>

  <div class="bottom-links">
    <a href={`${base}daily/`} class="big-link">🔥 デイリーランキング</a>
    <a href={`${base}all/`} class="big-link">🏆 全体ランキングを見る</a>
    <a href={`${base}tracks/`} class="big-link">🎶 曲ランキング</a>
    <a href={`${base}search/`} class="big-link">🔍 アーティストを検索</a>
  </div>
</Layout>

<script>
  document.querySelectorAll('.genre-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.genre-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const genre = btn.getAttribute('data-genre') || 'all';
      const cards = document.querySelectorAll('.rank-card');
      let visibleCount = 0;
      let rank = 1;
      cards.forEach(card => {
        const show = genre === 'all' || card.getAttribute('data-genre') === genre;
        (card as HTMLElement).style.display = show ? 'flex' : 'none';
        if (show) {
          const numEl = card.querySelector('.rank-number');
          if (numEl) {
            numEl.textContent = String(rank);
            numEl.classList.remove('gold', 'silver', 'bronze');
            if (rank === 1) numEl.classList.add('gold');
            else if (rank === 2) numEl.classList.add('silver');
            else if (rank === 3) numEl.classList.add('bronze');
          }
          rank++;
          visibleCount++;
        }
      });
      const noResults = document.querySelector('.no-results') as HTMLElement;
      if (noResults) noResults.style.display = visibleCount === 0 ? 'block' : 'none';
    });
  });
</script>

<style>
  .hero {
    text-align: center;
    padding: 1.5rem 0 1rem;
  }
  .hero h1 {
    font-size: 2.8rem;
    font-weight: 900;
    background: linear-gradient(135deg, #e040fb, #7c4dff, #448aff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 0.5rem;
  }
  .subtitle { color: var(--text-sub); font-size: 1.1rem; margin-bottom: 0.3rem; }
  .update { color: #666; font-size: 0.85rem; }

  .genre-filters {
    display: flex;
    gap: 0.4rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }
  .genre-btn {
    padding: 0.4rem 0.8rem;
    border: 1.5px solid #444;
    border-radius: 8px;
    background: transparent;
    color: var(--text-sub);
    font-family: inherit;
    font-size: 0.8rem;
    cursor: pointer;
    transition: all 0.2s;
  }
  .genre-btn:hover {
    border-color: var(--genre-color, var(--accent));
    color: var(--genre-color, var(--accent));
  }
  .genre-btn.active {
    background: var(--genre-color, var(--accent));
    border-color: var(--genre-color, var(--accent));
    color: #fff;
  }

  .ranking-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .rank-card {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 0.8rem 1rem;
    background: var(--bg-card);
    border-radius: 12px;
    transition: background 0.2s;
  }
  .rank-card:hover { background: var(--bg-hover); }

  .rank-number {
    font-size: 1.4rem;
    font-weight: 900;
    width: 2.2rem;
    text-align: center;
    color: var(--text-sub);
    flex-shrink: 0;
  }
  .gold { color: #ffd700 !important; }
  .silver { color: #c0c0c0 !important; }
  .bronze { color: #cd7f32 !important; }

  .change {
    width: 2.5rem;
    text-align: center;
    flex-shrink: 0;
  }

  .artist-info { flex: 1; min-width: 0; }
  .artist-name { font-weight: 700; font-size: 1rem; margin-bottom: 0.2rem; }
  .artist-meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
  }
  .genre-tag {
    font-size: 0.7rem;
    padding: 0.1rem 0.5rem;
    border-radius: 4px;
    background: color-mix(in srgb, var(--tag-color) 20%, transparent);
    color: var(--tag-color);
    font-weight: 700;
    white-space: nowrap;
  }
  .artist-stats { font-size: 0.8rem; color: var(--text-sub); }

  .spotify-link {
    display: flex;
    align-items: center;
    opacity: 0.7;
    transition: opacity 0.2s;
    flex-shrink: 0;
  }
  .spotify-link:hover { opacity: 1; }

  .bottom-links {
    display: flex;
    gap: 1rem;
    margin-top: 3rem;
    flex-wrap: wrap;
  }
  .big-link {
    flex: 1;
    min-width: 200px;
    padding: 1.2rem;
    text-align: center;
    background: var(--bg-card);
    border: 2px solid #333;
    border-radius: 16px;
    font-size: 1.1rem;
    font-weight: 700;
    transition: all 0.2s;
  }
  .big-link:hover { border-color: var(--accent); background: var(--bg-hover); }

  .no-results {
    text-align: center;
    color: var(--text-sub);
    padding: 3rem;
    font-size: 1.1rem;
  }

  @media (max-width: 600px) {
    .hero h1 { font-size: 2rem; }
    .rank-card { padding: 0.6rem 0.8rem; gap: 0.5rem; }
    .change { width: 2rem; }
  }
</style>
