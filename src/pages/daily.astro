---
import Layout from '../layouts/Layout.astro';
import rankings from '../data/rankings.json';
import artistData from '../data/artists.json';

const genres = artistData.genres;
const base = import.meta.env.BASE_URL;

// 全カテゴリから曲を集めてユニーク化、デイリー再生数順
const tracksMap = new Map();
for (const cat of rankings.categories) {
  for (const artist of cat.artists) {
    if (!artist.topTracks) continue;
    for (const track of artist.topTracks) {
      const key = `${artist.name}::${track.name}`;
      if (!tracksMap.has(key)) {
        tracksMap.set(key, {
          trackName: track.name,
          artistName: artist.name,
          playcount: track.playcount,
          dailyPlays: track.dailyPlays || 0,
          weeklyPlays: track.weeklyPlays || 0,
          genre: artist.genre,
          spotify_id: artist.spotify_id,
          year: track.year || null,
        });
      }
    }
  }
}
const allTracks = [...tracksMap.values()].sort((a, b) => {
  if (b.dailyPlays !== a.dailyPlays) return b.dailyPlays - a.dailyPlays;
  if (b.weeklyPlays !== a.weeklyPlays) return b.weeklyPlays - a.weeklyPlays;
  return b.playcount - a.playcount;
});
allTracks.forEach((t, i) => { t.rank = i + 1; });

// デイリーのアーティストランキング
const artistsMap = new Map();
for (const cat of rankings.categories) {
  for (const a of cat.artists) {
    if (!artistsMap.has(a.name) || (artistsMap.get(a.name).dailyPlays || 0) < (a.dailyPlays || 0)) {
      artistsMap.set(a.name, a);
    }
  }
}
const dailyArtists = [...artistsMap.values()].sort((a, b) => {
  const da = a.dailyPlays || 0;
  const db = b.dailyPlays || 0;
  if (db !== da) return db - da;
  return (b.weeklyPlays || 0) - (a.weeklyPlays || 0);
});
dailyArtists.forEach((a, i) => { a.dailyRank = i + 1; });

const updatedDate = new Date(rankings.fetchedAt).toLocaleDateString('ja-JP');

function formatNumber(n: number): string {
  if (n >= 1_000_000) return (n / 1_000_000).toFixed(1) + 'M';
  if (n >= 1_000) return (n / 1_000).toFixed(0) + 'K';
  return n.toString();
}
---

<Layout title="デイリーランキング - Music Ranking">
  <a href={base} class="back">&larr; トップに戻る</a>

  <div class="header">
    <h1>Daily Ranking</h1>
    <p class="subtitle">前日比で最も再生が伸びた曲・アーティスト</p>
    <p class="update">Updated: {updatedDate}</p>
  </div>

  <!-- タブ切り替え -->
  <div class="tab-bar">
    <button class="tab active" data-tab="tracks">曲</button>
    <button class="tab" data-tab="artists">アーティスト</button>
  </div>

  <!-- 共通ジャンルフィルター -->
  <div class="genre-filters">
    <button class="genre-btn active" data-genre="all">すべて</button>
    {genres.map((g) => (
      <button class="genre-btn" data-genre={g.id} style={`--genre-color: ${g.color}`}>
        {g.name}
      </button>
    ))}
  </div>

  <!-- 曲テーブル -->
  <div class="tab-panel active" id="panel-tracks">
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th class="col-rank">#</th>
            <th class="col-track">曲名</th>
            <th class="col-artist">アーティスト</th>
            <th class="col-genre">ジャンル</th>
            <th class="col-daily">今日</th>
            <th class="col-weekly">週間</th>
          </tr>
        </thead>
        <tbody>
          {allTracks.slice(0, 100).map((track, i) => (
            <tr data-genre={track.genre}>
              <td class:list={['col-rank', { gold: i === 0, silver: i === 1, bronze: i === 2 }]}>
                {track.rank}
              </td>
              <td class="col-track">
                <span class="track-name">{track.trackName}</span>
              </td>
              <td class="col-artist">
                {track.spotify_id ? (
                  <a href={`https://open.spotify.com/artist/${track.spotify_id}`} target="_blank" class="artist-link">
                    {track.artistName}
                  </a>
                ) : (
                  <span>{track.artistName}</span>
                )}
              </td>
              <td class="col-genre">
                <span class="genre-tag" style={`--tag-color: ${genres.find(g => g.id === track.genre)?.color || '#888'}`}>
                  {genres.find(g => g.id === track.genre)?.name || ''}
                </span>
              </td>
              <td class="col-daily">{track.dailyPlays > 0 ? `+${formatNumber(track.dailyPlays)}` : '-'}</td>
              <td class="col-weekly">{track.weeklyPlays > 0 ? `+${formatNumber(track.weeklyPlays)}` : '-'}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <!-- アーティストテーブル -->
  <div class="tab-panel" id="panel-artists">
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th class="col-rank">#</th>
            <th class="col-name">アーティスト</th>
            <th class="col-genre">ジャンル</th>
            <th class="col-daily">今日</th>
            <th class="col-weekly">週間</th>
            <th class="col-link"></th>
          </tr>
        </thead>
        <tbody>
          {dailyArtists.map((artist, i) => (
            <tr data-genre={artist.genre}>
              <td class:list={['col-rank', { gold: i === 0, silver: i === 1, bronze: i === 2 }]}>
                {i + 1}
              </td>
              <td class="col-name">
                <span class="artist-name">{artist.name}</span>
              </td>
              <td class="col-genre">
                <span class="genre-tag" style={`--tag-color: ${genres.find(g => g.id === artist.genre)?.color || '#888'}`}>
                  {genres.find(g => g.id === artist.genre)?.name || ''}
                </span>
              </td>
              <td class="col-daily">{(artist.dailyPlays || 0) > 0 ? `+${formatNumber(artist.dailyPlays)}` : '-'}</td>
              <td class="col-weekly">{(artist.weeklyPlays || 0) > 0 ? `+${formatNumber(artist.weeklyPlays)}` : '-'}</td>
              <td class="col-link">
                {artist.spotify_id && (
                  <a href={`https://open.spotify.com/artist/${artist.spotify_id}`} target="_blank" class="spotify-link">
                    <svg viewBox="0 0 24 24" width="20" height="20" fill="#1DB954">
                      <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/>
                    </svg>
                  </a>
                )}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</Layout>

<script>
  // タブ切り替え
  document.querySelectorAll('.tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      const target = tab.getAttribute('data-tab');
      document.querySelectorAll('.tab-panel').forEach(p => {
        p.classList.toggle('active', p.id === `panel-${target}`);
      });
      // ジャンルフィルターリセット
      document.querySelectorAll('.genre-btn').forEach(b => b.classList.remove('active'));
      document.querySelector('.genre-btn[data-genre="all"]')?.classList.add('active');
      applyGenreFilter('all');
    });
  });

  // ジャンルフィルター
  document.querySelectorAll('.genre-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.genre-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      applyGenreFilter(btn.getAttribute('data-genre') || 'all');
    });
  });

  function applyGenreFilter(genre: string) {
    const activePanel = document.querySelector('.tab-panel.active');
    if (!activePanel) return;
    const rows = activePanel.querySelectorAll('tbody tr');
    let rank = 1;
    rows.forEach(row => {
      const show = genre === 'all' || row.getAttribute('data-genre') === genre;
      (row as HTMLElement).style.display = show ? '' : 'none';
      if (show) {
        const cell = row.querySelector('.col-rank');
        if (cell) {
          cell.textContent = String(rank);
          cell.classList.remove('gold', 'silver', 'bronze');
          if (rank === 1) cell.classList.add('gold');
          else if (rank === 2) cell.classList.add('silver');
          else if (rank === 3) cell.classList.add('bronze');
        }
        rank++;
      }
    });
  }
</script>

<style>
  .back {
    display: inline-block;
    color: var(--accent);
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }
  .back:hover { text-decoration: underline; }

  .header { text-align: center; margin-bottom: 1.5rem; }
  .header h1 {
    font-size: 2.2rem;
    font-weight: 900;
    background: linear-gradient(135deg, #ff6b6b, #ffd93d, #6bcb77);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 0.3rem;
  }
  .subtitle { color: var(--text-sub); font-size: 0.95rem; margin-bottom: 0.2rem; }
  .update { color: #666; font-size: 0.8rem; }

  .tab-bar {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }
  .tab {
    padding: 0.6rem 1.5rem;
    border: 2px solid #333;
    border-radius: 999px;
    background: transparent;
    color: var(--text);
    font-family: inherit;
    font-size: 0.95rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s;
  }
  .tab:hover { border-color: var(--accent); }
  .tab.active {
    background: var(--gradient);
    border-color: transparent;
    color: #fff;
  }

  .genre-filters {
    display: flex;
    gap: 0.4rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }
  .genre-btn {
    padding: 0.4rem 0.8rem;
    border: 1.5px solid #444;
    border-radius: 8px;
    background: transparent;
    color: var(--text-sub);
    font-family: inherit;
    font-size: 0.8rem;
    cursor: pointer;
    transition: all 0.2s;
  }
  .genre-btn:hover {
    border-color: var(--genre-color, var(--accent));
    color: var(--genre-color, var(--accent));
  }
  .genre-btn.active {
    background: var(--genre-color, var(--accent));
    border-color: var(--genre-color, var(--accent));
    color: #fff;
  }

  .tab-panel { display: none; }
  .tab-panel.active { display: block; }

  .table-wrap { overflow-x: auto; }

  table { width: 100%; border-collapse: collapse; }
  thead th {
    text-align: left;
    padding: 0.6rem 0.8rem;
    border-bottom: 2px solid #333;
    color: var(--text-sub);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  tbody tr {
    border-bottom: 1px solid #1e1e30;
    transition: background 0.15s;
  }
  tbody tr:hover { background: var(--bg-card); }
  td { padding: 0.6rem 0.8rem; font-size: 0.9rem; }

  .col-rank {
    font-weight: 900;
    font-size: 1rem;
    width: 3rem;
    text-align: center;
    color: var(--text-sub);
  }
  .gold { color: #ffd700 !important; }
  .silver { color: #c0c0c0 !important; }
  .bronze { color: #cd7f32 !important; }

  .track-name, .artist-name { font-weight: 700; }

  .artist-link {
    color: var(--accent);
    transition: opacity 0.2s;
  }
  .artist-link:hover { text-decoration: underline; }

  .genre-tag {
    font-size: 0.7rem;
    padding: 0.1rem 0.5rem;
    border-radius: 4px;
    background: color-mix(in srgb, var(--tag-color) 20%, transparent);
    color: var(--tag-color);
    font-weight: 700;
    white-space: nowrap;
  }

  .col-daily {
    text-align: right;
    font-variant-numeric: tabular-nums;
    color: #ff6b6b;
    font-size: 0.9rem;
    font-weight: 700;
    white-space: nowrap;
  }

  .col-weekly {
    text-align: right;
    font-variant-numeric: tabular-nums;
    color: var(--up);
    font-size: 0.85rem;
    font-weight: 700;
    white-space: nowrap;
  }

  .spotify-link { opacity: 0.7; transition: opacity 0.2s; }
  .spotify-link:hover { opacity: 1; }

  @media (max-width: 600px) {
    .col-genre, .col-weekly { display: none; }
    td, th { padding: 0.4rem; font-size: 0.85rem; }
  }
</style>
