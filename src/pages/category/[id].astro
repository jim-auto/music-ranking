---
import Layout from '../../layouts/Layout.astro';
import rankings from '../../data/rankings.json';
import artistData from '../../data/artists.json';

export function getStaticPaths() {
  return rankings.categories.map((cat) => ({
    params: { id: cat.id },
    props: { category: cat },
  }));
}

const { category } = Astro.props;
const genres = artistData.genres;
const base = import.meta.env.BASE_URL;

// このカテゴリに存在するジャンルだけ抽出
const categoryGenreIds = [...new Set(category.artists.map((a) => a.genre))];
const categoryGenres = genres.filter((g) => categoryGenreIds.includes(g.id));

function formatNumber(n: number): string {
  if (n >= 1_000_000) return (n / 1_000_000).toFixed(1) + 'M';
  if (n >= 1_000) return (n / 1_000).toFixed(0) + 'K';
  return n.toString();
}

function changeLabel(change: number | null): string {
  if (change === null) return '<span class="change-new">NEW</span>';
  if (change > 0) return `<span class="change-up">▲${change}</span>`;
  if (change < 0) return `<span class="change-down">▼${Math.abs(change)}</span>`;
  return '<span class="change-same">-</span>';
}
---

<Layout title={`${category.emoji} ${category.name} - Music Ranking`}>
  <a href={base} class="back">&larr; トップに戻る</a>

  <div class="header">
    <h1>{category.emoji} {category.name}</h1>
    <p class="count">{category.artists.length} artists</p>
  </div>

  <!-- ジャンルフィルター -->
  <div class="genre-filters">
    <button class="genre-btn active" data-genre="all">すべて</button>
    {categoryGenres.map((g) => (
      <button class="genre-btn" data-genre={g.id} style={`--genre-color: ${g.color}`}>
        {g.name}
      </button>
    ))}
  </div>

  <div class="ranking-list">
    {category.artists.map((artist, i) => (
      <div class="rank-card" data-genre={artist.genre}>
        <div class:list={['rank-number', { gold: i === 0, silver: i === 1, bronze: i === 2 }]}>
          {artist.rank}
        </div>
        <div class="change" set:html={changeLabel(artist.change)} />
        <div class="artist-info">
          <div class="artist-name">{artist.name}</div>
          <div class="artist-meta">
            <span class="genre-tag" style={`--tag-color: ${genres.find(g => g.id === artist.genre)?.color || '#888'}`}>
              {genres.find(g => g.id === artist.genre)?.name || artist.genre}
            </span>
            <span class="artist-stats">
              {formatNumber(artist.listeners)} listeners &middot; {formatNumber(artist.playcount)} plays
            </span>
          </div>
        </div>
        <div class="right-area">
          {artist.topTracks && artist.topTracks.length > 0 && (
            <div class="top-tracks">
              <div class="tracks-label">Top Tracks</div>
              {artist.topTracks.map((track, ti) => (
                <div class="track">
                  <span class="track-num">{ti + 1}.</span>
                  <span class="track-name">{track.name}</span>
                  <span class="track-plays">{formatNumber(track.playcount)}</span>
                </div>
              ))}
            </div>
          )}
          {artist.spotify_id && (
            <div class="player-area">
              <iframe
                src={`https://open.spotify.com/embed/artist/${artist.spotify_id}?utm_source=generator&theme=0`}
                width="300"
                height="152"
                frameborder="0"
                allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
                loading="lazy"
                style="border-radius: 12px;"
              ></iframe>
            </div>
          )}
        </div>
      </div>
    ))}
  </div>

  <div class="no-results" style="display:none;">該当するアーティストがいません</div>
</Layout>

<script>
  document.querySelectorAll('.genre-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.genre-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const genre = btn.getAttribute('data-genre') || 'all';

      const cards = document.querySelectorAll('.rank-card');
      let visibleCount = 0;
      let rank = 1;

      cards.forEach(card => {
        const cardGenre = card.getAttribute('data-genre');
        const show = genre === 'all' || cardGenre === genre;
        (card as HTMLElement).style.display = show ? 'flex' : 'none';
        if (show) {
          const numEl = card.querySelector('.rank-number');
          if (numEl) {
            numEl.textContent = String(rank);
            numEl.classList.remove('gold', 'silver', 'bronze');
            if (rank === 1) numEl.classList.add('gold');
            else if (rank === 2) numEl.classList.add('silver');
            else if (rank === 3) numEl.classList.add('bronze');
          }
          rank++;
          visibleCount++;
        }
      });

      const noResults = document.querySelector('.no-results') as HTMLElement;
      if (noResults) noResults.style.display = visibleCount === 0 ? 'block' : 'none';
    });
  });
</script>

<style>
  .back {
    display: inline-block;
    color: var(--accent);
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }

  .back:hover { text-decoration: underline; }

  .header {
    margin-bottom: 1rem;
  }

  .header h1 {
    font-size: 2rem;
    font-weight: 900;
    margin-bottom: 0.3rem;
  }

  .count {
    color: var(--text-sub);
    font-size: 0.9rem;
  }

  .genre-filters {
    display: flex;
    gap: 0.4rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .genre-btn {
    padding: 0.4rem 0.8rem;
    border: 1.5px solid #444;
    border-radius: 8px;
    background: transparent;
    color: var(--text-sub);
    font-family: inherit;
    font-size: 0.8rem;
    cursor: pointer;
    transition: all 0.2s;
  }

  .genre-btn:hover {
    border-color: var(--genre-color, var(--accent));
    color: var(--genre-color, var(--accent));
  }

  .genre-btn.active {
    background: var(--genre-color, var(--accent));
    border-color: var(--genre-color, var(--accent));
    color: #fff;
  }

  .ranking-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .rank-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.2rem;
    background: var(--bg-card);
    border-radius: 12px;
    transition: background 0.2s;
    flex-wrap: wrap;
  }

  .rank-card:hover {
    background: var(--bg-hover);
  }

  .rank-number {
    font-size: 1.8rem;
    font-weight: 900;
    width: 3rem;
    text-align: center;
    color: var(--text-sub);
    flex-shrink: 0;
  }

  .change {
    width: 2.5rem;
    text-align: center;
    flex-shrink: 0;
  }

  .gold { color: #ffd700 !important; }
  .silver { color: #c0c0c0 !important; }
  .bronze { color: #cd7f32 !important; }

  .artist-info {
    flex: 1;
    min-width: 150px;
  }

  .artist-name {
    font-weight: 700;
    font-size: 1.1rem;
    margin-bottom: 0.3rem;
  }

  .artist-meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .genre-tag {
    font-size: 0.7rem;
    padding: 0.1rem 0.5rem;
    border-radius: 4px;
    background: color-mix(in srgb, var(--tag-color) 20%, transparent);
    color: var(--tag-color);
    font-weight: 700;
    white-space: nowrap;
  }

  .artist-stats {
    font-size: 0.85rem;
    color: var(--text-sub);
  }

  .right-area {
    display: flex;
    gap: 1rem;
    flex-shrink: 0;
    align-items: flex-start;
    flex-wrap: wrap;
  }

  .top-tracks {
    min-width: 200px;
  }

  .tracks-label {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--text-sub);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.3rem;
  }

  .track {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    padding: 0.15rem 0;
    color: var(--text-sub);
  }

  .track-num {
    color: #555;
    width: 1.2rem;
    flex-shrink: 0;
  }

  .track-name {
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: var(--text);
  }

  .track-plays {
    color: #555;
    font-size: 0.75rem;
    font-variant-numeric: tabular-nums;
  }

  .player-area {
    flex-shrink: 0;
  }

  .no-results {
    text-align: center;
    color: var(--text-sub);
    padding: 3rem;
    font-size: 1.1rem;
  }

  @media (max-width: 700px) {
    .rank-card {
      flex-direction: column;
      align-items: flex-start;
    }

    .rank-number {
      font-size: 1.2rem;
      width: auto;
    }

    .player-area {
      width: 100%;
    }

    .player-area iframe {
      width: 100%;
    }
  }
</style>
