---
import Layout from '../layouts/Layout.astro';
import rankings from '../data/rankings.json';
import artistData from '../data/artists.json';

const genres = artistData.genres;

// 全カテゴリからユニークなアーティストを集めてlistenersでソート
const allArtistsMap = new Map();
for (const cat of rankings.categories) {
  for (const a of cat.artists) {
    const key = a.name;
    if (!allArtistsMap.has(key) || allArtistsMap.get(key).listeners < a.listeners) {
      allArtistsMap.set(key, a);
    }
  }
}
const allArtists = [...allArtistsMap.values()].sort((a, b) => b.listeners - a.listeners);
allArtists.forEach((a, i) => { a.globalRank = i + 1; });

function formatNumber(n: number): string {
  if (n >= 1_000_000) return (n / 1_000_000).toFixed(1) + 'M';
  if (n >= 1_000) return (n / 1_000).toFixed(0) + 'K';
  return n.toString();
}
---

<Layout title="全体ランキング - Music Ranking">
  <a href="/" class="back">&larr; トップに戻る</a>

  <div class="header">
    <h1>🏆 全体ランキング</h1>
    <p class="count">全 {allArtists.length} アーティスト</p>
  </div>

  <div class="genre-filters">
    <button class="genre-btn active" data-genre="all">すべて</button>
    {genres.map((g) => (
      <button class="genre-btn" data-genre={g.id} style={`--genre-color: ${g.color}`}>
        {g.name}
      </button>
    ))}
  </div>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th class="col-rank">#</th>
          <th class="col-name">アーティスト</th>
          <th class="col-genre">ジャンル</th>
          <th class="col-listeners">Listeners</th>
          <th class="col-plays">Plays</th>
          <th class="col-link"></th>
        </tr>
      </thead>
      <tbody>
        {allArtists.map((artist, i) => (
          <tr data-genre={artist.genre}>
            <td class:list={['col-rank', { gold: i === 0, silver: i === 1, bronze: i === 2 }]}>
              {i + 1}
            </td>
            <td class="col-name">
              <span class="artist-name">{artist.name}</span>
            </td>
            <td class="col-genre">
              <span class="genre-tag" style={`--tag-color: ${genres.find(g => g.id === artist.genre)?.color || '#888'}`}>
                {genres.find(g => g.id === artist.genre)?.name || ''}
              </span>
            </td>
            <td class="col-listeners">{formatNumber(artist.listeners)}</td>
            <td class="col-plays">{formatNumber(artist.playcount)}</td>
            <td class="col-link">
              {artist.spotify_id && (
                <a href={`https://open.spotify.com/artist/${artist.spotify_id}`} target="_blank" class="spotify-link">
                  <svg viewBox="0 0 24 24" width="20" height="20" fill="#1DB954">
                    <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/>
                  </svg>
                </a>
              )}
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</Layout>

<script>
  document.querySelectorAll('.genre-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.genre-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const genre = btn.getAttribute('data-genre') || 'all';
      const rows = document.querySelectorAll('tbody tr');
      let rank = 1;
      rows.forEach(row => {
        const rowGenre = row.getAttribute('data-genre');
        const show = genre === 'all' || rowGenre === genre;
        (row as HTMLElement).style.display = show ? '' : 'none';
        if (show) {
          const cell = row.querySelector('.col-rank');
          if (cell) {
            cell.textContent = String(rank);
            cell.classList.remove('gold', 'silver', 'bronze');
            if (rank === 1) cell.classList.add('gold');
            else if (rank === 2) cell.classList.add('silver');
            else if (rank === 3) cell.classList.add('bronze');
          }
          rank++;
        }
      });
    });
  });
</script>

<style>
  .back {
    display: inline-block;
    color: var(--accent);
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }
  .back:hover { text-decoration: underline; }

  .header { margin-bottom: 1rem; }
  .header h1 { font-size: 2rem; font-weight: 900; margin-bottom: 0.3rem; }
  .count { color: var(--text-sub); font-size: 0.9rem; }

  .genre-filters {
    display: flex;
    gap: 0.4rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }
  .genre-btn {
    padding: 0.4rem 0.8rem;
    border: 1.5px solid #444;
    border-radius: 8px;
    background: transparent;
    color: var(--text-sub);
    font-family: inherit;
    font-size: 0.8rem;
    cursor: pointer;
    transition: all 0.2s;
  }
  .genre-btn:hover {
    border-color: var(--genre-color, var(--accent));
    color: var(--genre-color, var(--accent));
  }
  .genre-btn.active {
    background: var(--genre-color, var(--accent));
    border-color: var(--genre-color, var(--accent));
    color: #fff;
  }

  .table-wrap { overflow-x: auto; }

  table {
    width: 100%;
    border-collapse: collapse;
  }
  thead th {
    text-align: left;
    padding: 0.6rem 0.8rem;
    border-bottom: 2px solid #333;
    color: var(--text-sub);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  tbody tr {
    border-bottom: 1px solid #1e1e30;
    transition: background 0.15s;
  }
  tbody tr:hover { background: var(--bg-card); }
  td {
    padding: 0.7rem 0.8rem;
    font-size: 0.9rem;
  }

  .col-rank {
    font-weight: 900;
    font-size: 1.1rem;
    width: 3rem;
    text-align: center;
    color: var(--text-sub);
  }
  .gold { color: #ffd700 !important; }
  .silver { color: #c0c0c0 !important; }
  .bronze { color: #cd7f32 !important; }

  .artist-name { font-weight: 700; }

  .genre-tag {
    font-size: 0.7rem;
    padding: 0.1rem 0.5rem;
    border-radius: 4px;
    background: color-mix(in srgb, var(--tag-color) 20%, transparent);
    color: var(--tag-color);
    font-weight: 700;
    white-space: nowrap;
  }

  .col-listeners, .col-plays {
    text-align: right;
    font-variant-numeric: tabular-nums;
    color: var(--text-sub);
  }

  .spotify-link { opacity: 0.7; transition: opacity 0.2s; }
  .spotify-link:hover { opacity: 1; }

  @media (max-width: 600px) {
    .col-genre, .col-plays { display: none; }
    td, th { padding: 0.5rem 0.4rem; }
  }
</style>
