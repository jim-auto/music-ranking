---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Zen+Kaku+Gothic+New:wght@400;700;900&display=swap" rel="stylesheet" />
</head>
<body>
  <header>
    <nav>
      <a href="/" class="logo">🎵 Music Ranking</a>
      <div class="nav-links">
        <a href="/">ホーム</a>
        <a href="/all/">アーティスト</a>
        <a href="/tracks/">曲</a>
        <a href="/search/">検索</a>
      </div>
    </nav>
  </header>
  <main>
    <slot />
  </main>
  <footer>
    <p>Data from <a href="https://www.last.fm/" target="_blank">Last.fm</a> | Updated daily</p>
  </footer>
</body>
</html>

<style is:global>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --bg: #0f0f1a;
    --bg-card: #1a1a2e;
    --bg-hover: #252542;
    --accent: #e040fb;
    --accent2: #7c4dff;
    --text: #eee;
    --text-sub: #999;
    --gradient: linear-gradient(135deg, #e040fb, #7c4dff);
    --up: #69f0ae;
    --down: #ff5252;
    --new: #ffd740;
  }

  body {
    font-family: 'Zen Kaku Gothic New', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
  }

  header {
    background: rgba(26, 26, 46, 0.9);
    border-bottom: 1px solid #333;
    padding: 0.8rem 2rem;
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(12px);
  }

  nav {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .logo {
    font-size: 1.3rem;
    font-weight: 900;
    background: var(--gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    text-decoration: none;
    white-space: nowrap;
  }

  .nav-links {
    display: flex;
    gap: 1.2rem;
    font-size: 0.9rem;
  }

  .nav-links a {
    color: var(--text-sub);
    text-decoration: none;
    transition: color 0.2s;
    white-space: nowrap;
  }

  .nav-links a:hover {
    color: var(--accent);
  }

  main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  footer {
    text-align: center;
    padding: 2rem;
    color: var(--text-sub);
    font-size: 0.85rem;
    border-top: 1px solid #222;
    margin-top: 3rem;
  }

  footer a { color: var(--accent); text-decoration: none; }

  a { color: inherit; text-decoration: none; }

  /* change indicators */
  .change-up { color: var(--up); font-size: 0.75rem; font-weight: 700; }
  .change-down { color: var(--down); font-size: 0.75rem; font-weight: 700; }
  .change-new { color: var(--new); font-size: 0.7rem; font-weight: 700; }
  .change-same { color: var(--text-sub); font-size: 0.7rem; }

  @media (max-width: 600px) {
    header { padding: 0.6rem 1rem; }
    nav { gap: 1rem; }
    .nav-links { gap: 0.8rem; font-size: 0.8rem; }
  }
</style>
